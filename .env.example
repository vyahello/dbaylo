# Copy to .env and fill in. Real environment variables override these.

# Telegram bot token from @BotFather (required to actually run the bot).
BOT_TOKEN=

# Owner lock (REQUIRED in production): the only Telegram user id allowed to use the
# bot. Leave empty/0 and the bot refuses everyone (fail-closed). Find your id via a
# bot like @userinfobot. This is personal medical data — never run without it.
OWNER_TELEGRAM_ID=

# Public base URL where Telegram delivers webhook updates (production, needs HTTPS).
# The webhook path is /webhook/{BOT_TOKEN}. Leave empty to run via long polling.
WEBHOOK_BASE_URL=

# Webhook server bind. Default 127.0.0.1 (nginx terminates TLS and proxies to it).
# Set WEB_HOST=0.0.0.0 only to expose the app directly without a reverse proxy.
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Database URL. Defaults to a local SQLite file at the repo root if unset.
DATABASE_URL=sqlite:///dbaylo.db

# Timezone for reminders / daily check-ins (discovery assumes Europe/Kyiv).
TZ=Europe/Kyiv

# Where original lab files are kept (Stage 2+).
STORAGE_DIR=data/files

# Lab extraction / humanization via the `claude` binary (Claude Code OAuth).
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_S=180
# The `claude` binary authenticates with a subscription OAuth token (NOT an API key).
# Generate one with `claude setup-token` (an `sk-ant-oat...` value). It MUST be in the
# bot's *process* environment: a systemd service runs ExecStart directly and does NOT
# source ~/.bashrc, so a token only exported there is invisible to the bot and every
# extraction fails with "Not logged in". Put it here so the unit's EnvironmentFile loads
# it. Keep the real value out of the repo.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Backups (deploy/backup.sh, run by the dbaylo-backup.timer) ------------------
# Where the backup archive goes. A LOCAL dir now (protects against accidental
# delete / DB corruption, NOT disk loss), or a remote later for real off-site
# safety (e.g. b2:my-bucket/dbaylo) — same script, just change this value.
BACKUP_RCLONE_REMOTE=~/.dbaylo/backups
# Days of backups to keep.
BACKUP_RETENTION_DAYS=14
# OPTIONAL encryption: set an age/SSH PUBLIC key (private key kept OFF the VPS) and
# the archive becomes .tar.age. Leave empty for a plain .tar.gz (fine locally, since
# the live DB is already plaintext on the same box). Set this before going off-box.
BACKUP_AGE_RECIPIENT=
